if _G.a then
    for _, v in pairs(_G.a) do
        v:Disconnect()
    end
    _G.a = nil
end

_G.WertUiAnimation = true
local WertUi = loadstring(game:HttpGet(
    "https://raw.githubusercontent.com/idcgj36/WertNotify/refs/heads/main/Obfuscate.lua",
    true
))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local Camera = workspace.CurrentCamera

local Character, Humanoid, RootPart
local InvisibleEnabled = false
local Parts = {}

local function NotifyInvisible(state)
    WertUi:Notify({
        Title = "Status",
        Description = state and "Enabled" or "Disabled",
        Duration = 2.5,
        Corner = 14,
        Transparent = 0.1,
        Icon = state and "rbxassetid://93898873302694" or "rbxassetid://110786993356448",
    })
end

local function CacheParts()
    Parts = {}
    if not Character then return end
    for _, v in ipairs(Character:GetDescendants()) do
        if v:IsA("BasePart") then
            Parts[#Parts + 1] = v
        end
    end
end

local function SetTransparency(value)
    for _, part in ipairs(Parts) do
        if part and part.Parent then
            part.Transparency = value
        end
    end
end

local function SetupCharacter(char)
    Character = char
    Humanoid = char:WaitForChild("Humanoid")
    RootPart = char:WaitForChild("HumanoidRootPart")

    CacheParts()

    if not InvisibleEnabled then
        SetTransparency(0)
        Humanoid.CameraOffset = Vector3.zero
    end
end

SetupCharacter(LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait())
LocalPlayer.CharacterAdded:Connect(SetupCharacter)

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Invisible"
ScreenGui.ResetOnSpawn = false
ScreenGui.DisplayOrder = 999
ScreenGui.Parent = PlayerGui

local Button = Instance.new("ImageButton")
Button.Parent = ScreenGui
Button.Size = UDim2.new(0, 138, 0, 40)
Button.Position = UDim2.new(0, 230, 0, 30)
Button.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Button.BorderSizePixel = 0
Button.Image = "rbxassetid://110623745821407"
Button.Active = true
Button.Draggable = true

Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 10)

local UIStroke = Instance.new("UIStroke", Button)
UIStroke.Thickness = 1.4
UIStroke.Color = Color3.fromRGB(255, 255, 255)

local UIGradient = Instance.new("UIGradient", UIStroke)
UIGradient.Rotation = 77
UIGradient.Color = ColorSequence.new({
    ColorSequenceKeypoint.new(0, Color3.fromRGB(241, 241, 241)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(21, 21, 21)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(241, 241, 241))
})

local Title = Instance.new("TextLabel", Button)
Title.BackgroundTransparency = 1
Title.Size = UDim2.new(0, 130, 0, 18)
Title.Position = UDim2.new(0, 4, 0, 10)
Title.Text = "Invisible"
Title.TextScaled = true
Title.TextColor3 = Color3.fromRGB(241, 241, 241)
Title.FontFace = Font.new(
    "rbxasset://fonts/families/SourceSansPro.json",
    Enum.FontWeight.SemiBold
)

TweenService:Create(
    UIGradient,
    TweenInfo.new(4.2, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1),
    { Rotation = 437 }
):Play()

Button.MouseButton1Click:Connect(function()
    InvisibleEnabled = not InvisibleEnabled

    if not InvisibleEnabled then
        SetTransparency(0)
        if Humanoid then
            Humanoid.CameraOffset = Vector3.zero
        end
    end

    NotifyInvisible(InvisibleEnabled)
end)

local Connections = {}

Connections[1] = RunService.Heartbeat:Connect(function()
    if not InvisibleEnabled or not Character or not Humanoid or not RootPart then
        return
    end

    local cf = RootPart.CFrame

    local newCF = cf * CFrame.new(0, -1000, 0)

    RootPart.CFrame = newCF * CFrame.Angles(math.rad(0), 0, 0)

    local camOffset = Humanoid.CameraOffset
    local offset = newCF:ToObjectSpace(CFrame.new(cf.Position)).Position

    Humanoid.CameraOffset = offset

    RunService.RenderStepped:Wait()

    RootPart.CFrame = cf
    Humanoid.CameraOffset = camOffset

    SetTransparency(0.4)
end)

_G.a = Connections