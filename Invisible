local function UpdateCheck(state)
    TweenService:Create(Check, TweenInfo.new(0.25), {
        ImageTransparency = state and 0 or 1
    }):Play()
end

InvisibleBtn.MouseButton1Click:Connect(function()
    InvisibleEnabled = not InvisibleEnabled
    _G.InvisibleEnabled = InvisibleEnabled

    if not InvisibleEnabled then        
        if RootPart and LastCF then
            RootPart.CFrame = LastCF
        end

        ResetTransparency()        
        if Humanoid then        
            Humanoid.CameraOffset = Vector3.zero        
        end        
    end        

    UpdateCheck(InvisibleEnabled)
end)

local Connections = {}

Connections[1] = RunService.Heartbeat:Connect(function()
    if not InvisibleEnabled or not Character or not Humanoid or not RootPart then
        return
    end

    local cf = RootPart.CFrame        
    LastCF = cf

    local newCF = cf * CFrame.new(0, -10000, 0)
    RootPart.CFrame = newCF * CFrame.Angles(math.rad(0.002), 0, 0)

    local camOffset = Humanoid.CameraOffset        
    local offset = newCF:ToObjectSpace(CFrame.new(cf.Position)).Position        

    Humanoid.CameraOffset = offset        

    RunService.RenderStepped:Wait()        

    if not InvisibleEnabled then return end        

    RootPart.CFrame = cf        
    Humanoid.CameraOffset = camOffset        

    SetTransparency(0.76)
end)

_G.a = Connections
