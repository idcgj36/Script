local function getClosestTarget()
    local closest = nil
    local shortestDistance = math.huge

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            if TeamCheck and v.Team == LocalPlayer.Team then continue end
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if distance < shortestDistance then
                    closest = v.Character
                    shortestDistance = distance
                end
            end
        end
    end

    if AllowedNPC then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(obj) and obj ~= LocalPlayer.Character then
                local hum = obj.Humanoid
                if hum.Health > 0 then
                    local pos, onScreen = Camera:WorldToViewportPoint(obj.HumanoidRootPart.Position)
                    if onScreen then
                        local distance = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if distance < shortestDistance then
                            closest = obj
                            shortestDistance = distance
                        end
                    end
                end
            end
        end
    end

    return closest
end

RunService.RenderStepped:Connect(function()
    if enabled then
        if (not LockedTarget) or (not LockedTarget.Parent) or (not LockedTarget:FindFirstChild("HumanoidRootPart")) or (LockedTarget:FindFirstChild("Humanoid") and LockedTarget.Humanoid.Health <= 0) then
            LockedTarget = getClosestTarget()
        end

        if LockedTarget and LockedTarget:FindFirstChild("HumanoidRootPart") then
            local isNPC = not Players:GetPlayerFromCharacter(LockedTarget)
            if not isNPC and TeamCheck then
                local p = Players:GetPlayerFromCharacter(LockedTarget)
                if p and p.Team == LocalPlayer.Team then
                    LockedTarget = nil
                    Highlight.Parent = nil
                    return
                end
            end

            local targetHit = nil 
            if TargetPart == "HumanoidRootPart" then 
                targetHit = LockedTarget:FindFirstChild("HumanoidRootPart") or LockedTarget:FindFirstChild("UpperTorso") or LockedTarget:FindFirstChild("Torso") 
            elseif TargetPart == "Head" then 
                targetHit = LockedTarget:FindFirstChild("Head") 
            elseif TargetPart == "LeftHand" then 
                targetHit = LockedTarget:FindFirstChild("LeftHand") or LockedTarget:FindFirstChild("Left Arm") 
            elseif TargetPart == "RightHand" then 
                targetHit = LockedTarget:FindFirstChild("RightHand") or LockedTarget:FindFirstChild("Right Arm") 
            elseif TargetPart == "LeftFoot" then 
                targetHit = LockedTarget:FindFirstChild("LeftFoot") or LockedTarget:FindFirstChild("Left Leg") 
            elseif TargetPart == "RightFoot" then 
                targetHit = LockedTarget:FindFirstChild("RightFoot") or LockedTarget:FindFirstChild("Right Leg") 
            end 
            
            local root = LockedTarget:FindFirstChild("HumanoidRootPart") 
            local hum = LockedTarget:FindFirstChild("Humanoid") 
            
            if root and targetHit and hum and hum.Health > 0 then 
                Highlight.Parent = LockedTarget
                if isNPC then
                    Highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    Highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                else
                    local color = Color3.fromHSV(tick() % 5 / 5, 1, 1) 
                    Highlight.FillColor = color 
                    Highlight.OutlineColor = color 
                end

                local offsetVector = Vector3.new(CamOffsetX, CamOffsetY, CamOffsetZ)
                local finalTargetPos = targetHit.Position + offsetVector

                if AimType == "Aim" then 
                    local targetCF = CFrame.new(Camera.CFrame.Position, finalTargetPos) 
                    Camera.CFrame = Camera.CFrame:Lerp(targetCF, AimSmooth) 
                elseif AimType == "Lock" then 
                    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if myRoot then 
                        local targetLookPos = Vector3.new(finalTargetPos.X, myRoot.Position.Y, finalTargetPos.Z) 
                        local targetCF = CFrame.new(myRoot.Position, targetLookPos) 
                        myRoot.CFrame = myRoot.CFrame:Lerp(targetCF, LockSmooth) 
                    end 
                end 
            else 
                Highlight.Parent = nil 
            end 
        else 
            Highlight.Parent = nil 
        end 
    else 
        Highlight.Parent = nil 
    end 
end)

local function tween(obj, info, props) TweenService:Create(obj, info, props):Play() end

local function setAim(v)
    enabled = v
    if enabled then
        Check.Visible = true
        tween(Check, TweenInfo.new(0.2), {ImageTransparency = 0})
        tween(AimLockBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0.05})
    else
        LockedTarget = nil
        tween(Check, TweenInfo.new(0.2), {ImageTransparency = 1})
        tween(AimLockBtn, TweenInfo.new(0.2), {BackgroundTransparency = 0.15})
        task.delay(0.2, function() if not enabled then Check.Visible = false end end)
    end
end

local function toggleSettings()
    settingsOpen = not settingsOpen
    ScrollHolder.Visible = settingsOpen
    if not settingsOpen then
        selectorOpen = false
        PartSelectorFrame.Visible = false
    end
end

AimLockBtn.MouseButton1Click:Connect(function()
    if LockDrag or not hasDragged then
        setAim(not enabled)
    end
end)

SettingsBtn.MouseButton1Click:Connect(function() toggleSettings() end)
ScreenGui.Destroying:Connect(function() enabled = false Highlight:Destroy() end)