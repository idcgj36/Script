local function CreateSlider(name, min, max, start, step, callback)
    local SliderFrame = Instance.new("Frame")
    SliderFrame.Size = UDim2.new(0, 135, 0, 45)
    SliderFrame.BackgroundTransparency = 1
    SliderFrame.Parent = SettingsScroll

    local Label = Instance.new("TextLabel") 
    Label.Size = UDim2.new(1, 0, 0, 15) 
    Label.BackgroundTransparency = 1 
    Label.Text = name .. ": " .. string.format("%.2f", start)
    Label.TextColor3 = Color3.fromRGB(255, 255, 255) 
    Label.Font = Enum.Font.SourceSansBold 
    Label.TextSize = 14 
    Label.Parent = SliderFrame 

    local SliderBack = Instance.new("Frame") 
    SliderBack.Size = UDim2.new(1, 0, 0, 14) 
    SliderBack.Position = UDim2.new(0, 0, 0, 22) 
    SliderBack.BackgroundColor3 = Color3.fromRGB(45, 45, 45) 
    SliderBack.BorderSizePixel = 0 
    SliderBack.Parent = SliderFrame 
    Instance.new("UICorner", SliderBack).CornerRadius = UDim.new(1, 0) 

    local SliderFillContainer = Instance.new("Frame")
    SliderFillContainer.Size = UDim2.new(1, 0, 1, 0)
    SliderFillContainer.BackgroundTransparency = 1
    SliderFillContainer.ClipsDescendants = true
    SliderFillContainer.Parent = SliderBack
    Instance.new("UICorner", SliderFillContainer).CornerRadius = UDim.new(1, 0)

    local SliderFill = Instance.new("Frame") 
    SliderFill.BackgroundColor3 = Color3.fromRGB(255, 255, 255) 
    SliderFill.BorderSizePixel = 0 
    SliderFill.Parent = SliderFillContainer 
    Instance.new("UICorner", SliderFill).CornerRadius = UDim.new(1, 0)

    local Knob = Instance.new("Frame") 
    Knob.Size = UDim2.new(0, 24, 0, 14) 
    Knob.AnchorPoint = Vector2.new(0, 0.5) 
    Knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255) 
    Knob.BorderSizePixel = 0 
    Knob.Parent = SliderBack 
    Instance.new("UICorner", Knob).CornerRadius = UDim.new(1, 0) 

    local sliderDragging = false 
    
    local function update(input) 
        local totalWidth = SliderBack.AbsoluteSize.X
        local usableWidth = totalWidth - 24
        local mouseX = input.Position.X - SliderBack.AbsolutePosition.X
        local currentXOffset = math.clamp(mouseX - 12, 0, usableWidth)
        
        local pos = usableWidth > 0 and (currentXOffset / usableWidth) or 0
        local value = min + (max - min) * pos
        
        if step and step > 0 then
            value = math.floor(value / step + 0.5) * step
        end
        value = math.clamp(value, min, max) 
        
        local exactPercent = (value - min) / (max - min)
        local knobOffset = exactPercent * usableWidth
        local fillWidth = knobOffset + 24

        TweenService:Create(Knob, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = UDim2.new(0, knobOffset, 0.5, 0)}):Play() 
        TweenService:Create(SliderFill, TweenInfo.new(0.05, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, fillWidth, 1, 0)}):Play() 
        
        Label.Text = name .. ": " .. string.format("%.2f", value) 
        callback(value) 
    end 

    local initPercent = (start - min) / (max - min)
    local initUsable = 135 - 24
    local initKnobOffset = initPercent * initUsable
    Knob.Position = UDim2.new(0, initKnobOffset, 0.5, 0)
    SliderFill.Size = UDim2.new(0, initKnobOffset + 24, 1, 0)
    
    SliderBack.InputBegan:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            sliderDragging = true 
            update(input) 
        end 
    end) 
    
    Knob.InputBegan:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            sliderDragging = true 
        end 
    end) 
    
    UserInputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then 
            sliderDragging = false 
        end 
    end) 
    
    UserInputService.InputChanged:Connect(function(input) 
        if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
            update(input) 
        end 
    end) 
end

