local FILE_NAME = "config.json"
local defaultConfig = {
    offsetX = 1.7,
    offsetY = -0.3,
    offsetZ = 0.0,
    crosshairScale = 1.0,
    crosshairImage = "rbxassetid://137321056643916",
    disabledColor = {255, 255, 255},
    enabledColor = {0, 150, 255}
}

local savedConfig = {}
for k, v in pairs(defaultConfig) do savedConfig[k] = v end

local function loadConfig()
    if isfile and isfile(FILE_NAME) then
        local success, content = pcall(readfile, FILE_NAME)
        if success then
            local success2, data = pcall(HttpService.JSONDecode, HttpService, content)
            if success2 and type(data) == "table" then
                for k, v in pairs(data) do
                    savedConfig[k] = v
                end
            end
        end
    end
end

local function saveConfig()
    if writefile then
        pcall(writefile, FILE_NAME, HttpService:JSONEncode(savedConfig))
    end
end

loadConfig()

